{% comment %}
  Vitahub Booking Widget
  Agregar en Shopify: Online Store → Themes → Customize → Collection pages
  → Add section → Custom Liquid → pegar este código.
  Funciona automáticamente usando el handle de la colección como slug del afiliado.
{% endcomment %}

{% assign booking_url = "https://pro.vitahub.mx/book/" | append: collection.handle | append: "?embed=1" %}

<style>
  .vhb-btn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9998;
    background: #1b3f7a;
    color: #fff;
    border: none;
    border-radius: 50px;
    padding: 14px 24px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(27,63,122,0.35);
    display: flex;
    align-items: center;
    gap: 8px;
    transition: transform 0.15s, box-shadow 0.15s;
    font-family: inherit;
  }
  .vhb-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(27,63,122,0.45);
  }
  .vhb-btn svg { flex-shrink: 0; }

  .vhb-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .vhb-overlay.open { display: flex; }

  .vhb-modal {
    background: #fff;
    border-radius: 20px;
    width: 100%;
    max-width: 480px;
    height: 90vh;
    max-height: 780px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    position: relative;
  }

  .vhb-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
  }
  .vhb-modal-header span {
    font-weight: 600;
    font-size: 15px;
    color: #1b3f7a;
  }
  .vhb-close {
    background: #f5f5f5;
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: #666;
    line-height: 1;
    transition: background 0.15s;
  }
  .vhb-close:hover { background: #eee; }

  .vhb-iframe {
    flex: 1;
    border: none;
    width: 100%;
  }

  .vhb-loader {
    position: absolute;
    inset: 60px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .vhb-loader.hidden { opacity: 0; }
  .vhb-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid #e5e7eb;
    border-top-color: #1b3f7a;
    border-radius: 50%;
    animation: vhb-spin 0.7s linear infinite;
  }
  @keyframes vhb-spin { to { transform: rotate(360deg); } }

  @media (max-width: 500px) {
    .vhb-modal {
      height: 100vh;
      max-height: 100vh;
      border-radius: 16px 16px 0 0;
    }
    .vhb-overlay { align-items: flex-end; padding: 0; }
    .vhb-btn { bottom: 16px; right: 16px; padding: 12px 18px; font-size: 14px; }
  }
</style>

<!-- Botón flotante -->
<button class="vhb-btn" id="vhb-open" aria-label="Reservar cita">
  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
    <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
  </svg>
  Reservar cita
</button>

<!-- Modal -->
<div class="vhb-overlay" id="vhb-overlay" role="dialog" aria-modal="true">
  <div class="vhb-modal">
    <div class="vhb-modal-header">
      <span>Reservar cita</span>
      <button class="vhb-close" id="vhb-close" aria-label="Cerrar">×</button>
    </div>
    <div class="vhb-loader" id="vhb-loader">
      <div class="vhb-spinner"></div>
    </div>
    <iframe
      class="vhb-iframe"
      id="vhb-iframe"
      src=""
      data-src="{{ booking_url }}"
      title="Reservar cita"
    ></iframe>
  </div>
</div>

<script>
  (function () {
    const overlay  = document.getElementById("vhb-overlay");
    const iframe   = document.getElementById("vhb-iframe");
    const loader   = document.getElementById("vhb-loader");
    const btnOpen  = document.getElementById("vhb-open");
    const btnClose = document.getElementById("vhb-close");
    let loaded = false;

    function openModal() {
      overlay.classList.add("open");
      document.body.style.overflow = "hidden";
      if (!loaded) {
        iframe.src = iframe.dataset.src;
        iframe.onload = () => loader.classList.add("hidden");
        loaded = true;
      }
    }

    function closeModal() {
      overlay.classList.remove("open");
      document.body.style.overflow = "";
    }

    btnOpen.addEventListener("click", openModal);
    btnClose.addEventListener("click", closeModal);
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });

    // Checkout de Shopify no permite iframe → el booking page envía postMessage
    window.addEventListener("message", (e) => {
      if (!e.data || e.data.type !== "vhb-checkout") return;
      if (e.data.url) window.top.location.href = e.data.url;
    });
  })();
</script>
