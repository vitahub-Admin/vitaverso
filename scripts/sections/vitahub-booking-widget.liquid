{% if section.settings.enable and collection.metafields.custom.afiliado_booking %}

<style>
  .vhb-card {
    background: #fff;
    border: 1px solid #e8edf5;
    border-radius: 16px;
    padding: 24px;
    margin: 24px 0;
    font-family: inherit;
  }
  .vhb-card-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }
  .vhb-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background: #e8edf5;
  }
  .vhb-avatar-placeholder {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #e8edf5;
    flex-shrink: 0;
  }
  .vhb-affiliate-name {
    font-size: 16px;
    font-weight: 700;
    color: #111;
    margin: 0 0 2px;
  }
  .vhb-affiliate-specialty {
    font-size: 13px;
    color: {{ section.settings.button_color }};
    margin: 0;
  }
  .vhb-section-title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #888;
    margin: 0 0 12px;
  }
  .vhb-services {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .vhb-service-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: #f8f9fc;
    border-radius: 12px;
    padding: 14px 16px;
  }
  .vhb-service-info { flex: 1; min-width: 0; }
  .vhb-service-name {
    font-size: 14px;
    font-weight: 600;
    color: #111;
    margin: 0 0 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .vhb-service-meta {
    font-size: 12px;
    color: #888;
    margin: 0;
  }
  .vhb-service-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .vhb-service-price {
    font-size: 15px;
    font-weight: 700;
    color: #111;
    white-space: nowrap;
  }
  .vhb-reserve-btn {
    background: {{ section.settings.button_color }};
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
    font-family: inherit;
  }
  .vhb-reserve-btn:hover { opacity: 0.85; }

  .vhb-skeleton {
    background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: vhb-shimmer 1.2s infinite;
    border-radius: 8px;
  }
  @keyframes vhb-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  .vhb-skeleton-line { height: 14px; margin-bottom: 8px; }

  /* Modal */
  .vhb-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .vhb-overlay.open { display: flex; }
  .vhb-modal {
    background: #fff;
    border-radius: 20px;
    width: 100%;
    max-width: 480px;
    height: 90vh;
    max-height: 800px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    position: relative;
  }
  .vhb-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
  }
  .vhb-modal-title { font-weight: 600; font-size: 15px; color: #111; }
  .vhb-close {
    background: #f5f5f5;
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: #666;
    transition: background 0.15s;
    font-family: inherit;
  }
  .vhb-close:hover { background: #e5e5e5; }
  .vhb-iframe { flex: 1; border: none; width: 100%; }
  .vhb-loader {
    position: absolute;
    inset: 61px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .vhb-loader.hidden { opacity: 0; }
  .vhb-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid #e5e7eb;
    border-top-color: {{ section.settings.button_color }};
    border-radius: 50%;
    animation: vhb-spin 0.7s linear infinite;
  }
  @keyframes vhb-spin { to { transform: rotate(360deg); } }

  @media (max-width: 500px) {
    .vhb-modal { height: 100vh; max-height: 100vh; border-radius: 16px 16px 0 0; }
    .vhb-overlay { align-items: flex-end; padding: 0; }
    .vhb-service-row { flex-wrap: wrap; }
    .vhb-service-right { width: 100%; justify-content: space-between; margin-top: 8px; }
  }
</style>

<!-- Card inline -->
<div class="vhb-card" id="vhb-card-{{ section.id }}">
  <div class="vhb-card-header" id="vhb-header-{{ section.id }}">
    <div class="vhb-avatar-placeholder vhb-skeleton"></div>
    <div style="flex:1">
      <div class="vhb-skeleton vhb-skeleton-line" style="width:60%"></div>
      <div class="vhb-skeleton vhb-skeleton-line" style="width:40%"></div>
    </div>
  </div>
  <p class="vhb-section-title">{{ section.settings.services_label }}</p>
  <div class="vhb-services" id="vhb-services-{{ section.id }}">
    <div class="vhb-service-row">
      <div class="vhb-skeleton vhb-skeleton-line" style="width:100%;height:48px;border-radius:12px"></div>
    </div>
  </div>
</div>

<!-- Modal -->
<div class="vhb-overlay" id="vhb-overlay-{{ section.id }}" role="dialog" aria-modal="true">
  <div class="vhb-modal">
    <div class="vhb-modal-header">
      <span class="vhb-modal-title">{{ section.settings.modal_title }}</span>
      <button class="vhb-close" id="vhb-close-{{ section.id }}" aria-label="Cerrar">&#x2715;</button>
    </div>
    <div class="vhb-loader" id="vhb-loader-{{ section.id }}">
      <div class="vhb-spinner"></div>
    </div>
    <iframe class="vhb-iframe" id="vhb-iframe-{{ section.id }}" src="" title="{{ section.settings.modal_title }}"></iframe>
  </div>
</div>

<script>
(function () {
  var sid       = "{{ section.id }}";
  var slug      = "{{ collection.handle }}";
  var baseUrl   = "https://pro.vitahub.mx";
  var overlay   = document.getElementById("vhb-overlay-" + sid);
  var iframe    = document.getElementById("vhb-iframe-" + sid);
  var loader    = document.getElementById("vhb-loader-" + sid);
  var btnClose  = document.getElementById("vhb-close-" + sid);
  var headerEl  = document.getElementById("vhb-header-" + sid);
  var servicesEl= document.getElementById("vhb-services-" + sid);
  var iframeLoaded = false;

  function fmt(price, currency) {
    return "$" + Number(price).toLocaleString("es-MX", { minimumFractionDigits: 0 }) + " " + currency;
  }

  function openModal(serviceId) {
    var src = baseUrl + "/book/" + slug + "?embed=1" + (serviceId ? "&service_id=" + serviceId : "");
    overlay.classList.add("open");
    document.body.style.overflow = "hidden";
    if (!iframeLoaded || iframe.dataset.current !== src) {
      loader.classList.remove("hidden");
      iframe.src = src;
      iframe.dataset.current = src;
      iframe.onload = function() { loader.classList.add("hidden"); };
      iframeLoaded = true;
    }
  }

  function closeModal() {
    overlay.classList.remove("open");
    document.body.style.overflow = "";
  }

  btnClose.addEventListener("click", closeModal);
  overlay.addEventListener("click", function(e) { if (e.target === overlay) closeModal(); });
  document.addEventListener("keydown", function(e) { if (e.key === "Escape") closeModal(); });

  window.addEventListener("message", function(e) {
    if (!e.data || e.data.type !== "vhb-checkout") return;
    if (e.data.url) window.top.location.href = e.data.url;
  });

  // Cargar datos del afiliado
  fetch(baseUrl + "/api/booking/affiliate?slug=" + slug)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      // Header
      var avatarHtml = data.photo_url
        ? '<img class="vhb-avatar" src="' + data.photo_url + '" alt="' + data.display_name + '">'
        : '<div class="vhb-avatar-placeholder"></div>';
      headerEl.innerHTML = avatarHtml +
        '<div><p class="vhb-affiliate-name">' + data.display_name + '</p>' +
        (data.specialty ? '<p class="vhb-affiliate-specialty">' + data.specialty + '</p>' : '') +
        '</div>';

      // Servicios
      var services = data.booking_services || [];
      if (services.length === 0) {
        servicesEl.innerHTML = '<p style="color:#999;font-size:13px">Sin servicios disponibles</p>';
        return;
      }
      servicesEl.innerHTML = services.map(function(s) {
        return '<div class="vhb-service-row">' +
          '<div class="vhb-service-info">' +
            '<p class="vhb-service-name">' + s.name + '</p>' +
            '<p class="vhb-service-meta">' + s.duration_minutes + ' min' +
              (s.description ? ' · ' + s.description : '') +
            '</p>' +
          '</div>' +
          '<div class="vhb-service-right">' +
            '<span class="vhb-service-price">' + fmt(s.price, s.currency) + '</span>' +
            '<button class="vhb-reserve-btn" data-service-id="' + s.id + '">Reservar</button>' +
          '</div>' +
        '</div>';
      }).join("");

      servicesEl.querySelectorAll(".vhb-reserve-btn").forEach(function(btn) {
        btn.addEventListener("click", function() { openModal(btn.dataset.serviceId); });
      });
    })
    .catch(function() {
      servicesEl.innerHTML = '<p style="color:#999;font-size:13px">No se pudo cargar la información</p>';
    });
})();
</script>

{% endif %}

{% schema %}
{
  "name": "Vitahub Booking",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Activar widget de reservas",
      "default": true
    },
    {
      "type": "text",
      "id": "services_label",
      "label": "Título de la sección de servicios",
      "default": "Servicios disponibles"
    },
    {
      "type": "text",
      "id": "modal_title",
      "label": "Título del modal",
      "default": "Reservar cita"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Color de acento",
      "default": "#1b3f7a"
    }
  ],
  "presets": [
    {
      "name": "Vitahub Booking"
    }
  ]
}
{% endschema %}
