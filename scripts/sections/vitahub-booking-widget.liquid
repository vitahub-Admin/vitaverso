{% if section.settings.enable and collection.metafields.custom.afiliado_booking %}

<style>
  .vhb-card {
    background: #fff;
    border: 1px solid #e8edf5;
    border-radius: 16px;
    padding: 24px;
    margin: 24px auto;
    max-width: 1200px;
    font-family: inherit;
  }
  .vhb-section-title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #1b3f7a;
    margin: 0 0 14px;
  }
  .vhb-services {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .vhb-service-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: #f4f7fc;
    border-radius: 12px;
    padding: 14px 18px;
  }
  .vhb-service-info { flex: 1; min-width: 0; }
  .vhb-service-name {
    font-size: 14px;
    font-weight: 600;
    color: #111;
    margin: 0 0 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .vhb-service-meta {
    font-size: 12px;
    color: #888;
    margin: 0;
  }
  .vhb-service-right {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
  }
  .vhb-service-price {
    font-size: 15px;
    font-weight: 700;
    color: #1b3f7a;
    white-space: nowrap;
  }
  .vhb-reserve-btn {
    background: #1b3f7a;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 9px 18px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
    font-family: inherit;
  }
  .vhb-reserve-btn:hover { background: #16336a; }

  .vhb-skeleton {
    background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: vhb-shimmer 1.2s infinite;
    border-radius: 8px;
  }
  @keyframes vhb-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Modal — appended to body via JS para evitar z-index/transform del tema */
  .vhb-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.55);
    z-index: 2147483646;
    align-items: center;
    justify-content: center;
    padding: 16px;
    box-sizing: border-box;
  }
  .vhb-overlay.open { display: flex; }
  .vhb-modal {
    background: #fff;
    border-radius: 20px;
    width: 100%;
    max-width: 480px;
    height: 90vh;
    height: 90dvh;
    max-height: 800px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    position: relative;
  }
  .vhb-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
  }
  .vhb-modal-title { font-weight: 600; font-size: 15px; color: #111; }
  .vhb-close {
    background: #f5f5f5;
    border: none;
    border-radius: 50%;
    width: 32px; height: 32px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: #666;
    transition: background 0.15s;
    font-family: inherit;
  }
  .vhb-close:hover { background: #e5e5e5; }
  .vhb-iframe { flex: 1; border: none; width: 100%; }
  .vhb-loader {
    position: absolute;
    inset: 61px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .vhb-loader.hidden { opacity: 0; }
  .vhb-spinner {
    width: 32px; height: 32px;
    border: 3px solid #e5e7eb;
    border-top-color: #1b3f7a;
    border-radius: 50%;
    animation: vhb-spin 0.7s linear infinite;
  }
  @keyframes vhb-spin { to { transform: rotate(360deg); } }

  @media (max-width: 600px) {
    .vhb-overlay { padding: 0; align-items: flex-end; }
    .vhb-modal {
      border-radius: 20px 20px 0 0;
      max-width: 100%;
      height: 92vh;
      height: 92dvh;
      max-height: none;
    }
  }

  @media (max-width: 600px) {
    .vhb-card { margin: 12px; padding: 16px; }
    .vhb-service-row { flex-wrap: wrap; }
    .vhb-service-right { width: 100%; justify-content: space-between; margin-top: 8px; }
  }
</style>

<!-- Card inline (desktop) -->
<div class="vhb-card">
  <p class="vhb-section-title">{{ section.settings.cta_label }}</p>
  <div class="vhb-services" id="vhb-services-{{ section.id }}">
    <div class="vhb-service-row">
      <div class="vhb-skeleton" style="width:100%;height:46px;border-radius:12px"></div>
    </div>
    <div class="vhb-service-row">
      <div class="vhb-skeleton" style="width:75%;height:46px;border-radius:12px"></div>
    </div>
  </div>
</div>


<div class="vhb-overlay" id="vhb-overlay-{{ section.id }}" role="dialog" aria-modal="true">
  <div class="vhb-modal">
    <div class="vhb-modal-header">
      <span class="vhb-modal-title">{{ section.settings.modal_title }}</span>
      <button class="vhb-close" id="vhb-close-{{ section.id }}" aria-label="Cerrar">&#x2715;</button>
    </div>
    <div class="vhb-loader" id="vhb-loader-{{ section.id }}">
      <div class="vhb-spinner"></div>
    </div>
    <iframe class="vhb-iframe" id="vhb-iframe-{{ section.id }}" src="" title="{{ section.settings.modal_title }}"></iframe>
  </div>
</div>

<script>
(function () {
  var sid        = "{{ section.id }}";
  var slug       = "{{ collection.handle }}";
  var baseUrl    = "https://pro.vitahub.mx";
  var overlay    = document.getElementById("vhb-overlay-" + sid);
  var iframe     = document.getElementById("vhb-iframe-" + sid);
  var loader     = document.getElementById("vhb-loader-" + sid);
  var btnClose   = document.getElementById("vhb-close-" + sid);
  var servicesEl = document.getElementById("vhb-services-" + sid);

  // Mover overlay al body para que no quede atrapado en el z-index/transform del tema
  document.body.appendChild(overlay);

  function fmt(price, currency) {
    return "$" + Number(price).toLocaleString("es-MX", { minimumFractionDigits: 0 }) + " " + currency;
  }

  function openModal(serviceId) {
    var src = baseUrl + "/book/" + slug + "?embed=1&service_id=" + serviceId;
    overlay.classList.add("open");
    document.body.style.overflow = "hidden";
    if (iframe.dataset.current !== src) {
      loader.classList.remove("hidden");
      iframe.src = src;
      iframe.dataset.current = src;
      iframe.onload = function () { loader.classList.add("hidden"); };
    }
  }

  function closeModal() {
    overlay.classList.remove("open");
    document.body.style.overflow = "";
  }

  btnClose.addEventListener("click", closeModal);
  overlay.addEventListener("click", function (e) { if (e.target === overlay) closeModal(); });
  document.addEventListener("keydown", function (e) { if (e.key === "Escape") closeModal(); });

  window.addEventListener("message", function (e) {
    if (!e.data || e.data.type !== "vhb-checkout") return;
    if (e.data.url) window.top.location.href = e.data.url;
  });

  fetch(baseUrl + "/api/booking/affiliate?slug=" + slug)
    .then(function (r) { return r.json(); })
    .then(function (data) {
      var services = data.booking_services || [];
      if (services.length === 0) {
        servicesEl.innerHTML = '<p style="color:#999;font-size:13px;margin:0">Sin servicios disponibles</p>';
        return;
      }
      servicesEl.innerHTML = services.map(function (s) {
        return (
          '<div class="vhb-service-row">' +
            '<div class="vhb-service-info">' +
              '<p class="vhb-service-name">' + s.name + '</p>' +
              '<p class="vhb-service-meta">' + s.duration_minutes + ' min' +
                (s.description ? ' &middot; ' + s.description : '') +
              '</p>' +
            '</div>' +
            '<div class="vhb-service-right">' +
              '<span class="vhb-service-price">' + fmt(s.price, s.currency) + '</span>' +
              '<button class="vhb-reserve-btn" data-id="' + s.id + '">Reservar</button>' +
            '</div>' +
          '</div>'
        );
      }).join("");

      servicesEl.querySelectorAll(".vhb-reserve-btn").forEach(function (btn) {
        btn.addEventListener("click", function () { openModal(btn.dataset.id); });
      });
    })
    .catch(function () {
      servicesEl.innerHTML = '<p style="color:#c00;font-size:13px;margin:0">No se pudo cargar la información</p>';
    });
})();
</script>

{% endif %}

{% schema %}
{
  "name": "Afiliado Booking",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Activar widget de reservas",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Título de la sección",
      "default": "Agenda tu cita"
    },
    {
      "type": "text",
      "id": "modal_title",
      "label": "Título del modal",
      "default": "Reservar cita"
    }
  ],
  "presets": [
    {
      "name": "Afiliado Booking"
    }
  ]
}
{% endschema %}
